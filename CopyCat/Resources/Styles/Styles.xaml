<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:conv="clr-namespace:CopyCat.Converters"
                    x:Class="CopyCat.Resources.Styles.Styles">

    <!-- ══════════════════════════════════════════════════════════════════════
         COLORS — Design System
         ══════════════════════════════════════════════════════════════════════ -->
    
    <!-- App surfaces -->
    <Color x:Key="BgApp">#070F12</Color>
    <Color x:Key="BgCard">#003B46</Color>
    <Color x:Key="BgInput">#070F12</Color>
    <Color x:Key="BgStatus">#070F12</Color>
    <Color x:Key="BgSuccess">#0A1A12</Color>
    <Color x:Key="BgError">#200A0A</Color>
    <Color x:Key="BgPreview">#070F12</Color>
    <Color x:Key="BgPromptCard">#070F12</Color>
    <Color x:Key="BgPromptEdit">#070F12</Color>
    <Color x:Key="BgSmartBar">#070F12</Color>

    <!-- Chip states -->
    <Color x:Key="BgChipOn">#1A2E1A</Color>
    <Color x:Key="BgChipOff">#006770</Color>
    <Color x:Key="BgChipOnFolder">#003B46</Color>
    <Color x:Key="BgChipOnPattern">#2E1A1A</Color>

    <!-- Chunk card states -->
    <Color x:Key="BgChunkDefault">#070F12</Color>
    <Color x:Key="BgChunkCopied">#1A2E20</Color>
    <Color x:Key="BgChunkSelected">#17213A</Color>

    <!-- Selection toolbar -->
    <Color x:Key="BgSelectionToolbar">#070F12</Color>
    <Color x:Key="BorderSelectionToolbar">#00A3A9</Color>

    <!-- Primary accent: amber/gold — complements teal -->
    <Color x:Key="AccentPrimary">#F59E0B</Color>
    <Color x:Key="AccentPrimaryLight">#FCD34D</Color>
    <Color x:Key="AccentPrimaryBg">#22F59E0B</Color>
    <Color x:Key="AccentPrimaryBorder">#55F59E0B</Color>

    <!-- Secondary accent: teal — used for copy/success feedback and auto-detect -->
    <Color x:Key="AccentSecond">#008C8B</Color>
    <Color x:Key="AccentSecondLight">#00A3A9</Color>
    <Color x:Key="AccentSecondBg">#1A00D4AA</Color>
    <Color x:Key="AccentSecondBorder">#4400D4AA</Color>

    <!-- Legacy green kept for StatNumber and SummaryBorder (success state) -->
    <Color x:Key="AccentGreen">#22C55E</Color>
    <Color x:Key="AccentGreenBg">#3322C55E</Color>
    <Color x:Key="AccentGreenBorder">#3322C55E</Color>

    <Color x:Key="AccentRed">#FF7070</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#EEEEFF</Color>
    <Color x:Key="TextSecondary">#00A3A9</Color>
    <Color x:Key="TextMuted">#00A3A9</Color>
    <Color x:Key="TextDim">#00A3A9</Color>
    <Color x:Key="TextGreen">#2A7048</Color>
    <Color x:Key="TextError">#FF7070</Color>
    <Color x:Key="TextAccent">#FCD34D</Color>
    <Color x:Key="TextOnAccent">#FFFFFF</Color>
    <Color x:Key="TextCode">#00A3A9</Color>
    <Color x:Key="TextCopied">#008C8B</Color>

    <!-- Borders -->
    <Color x:Key="BorderDefault">#003B46</Color>
    <Color x:Key="BorderInput">#006770</Color>
    <Color x:Key="BorderSuccess">#3322C55E</Color>
    <Color x:Key="BorderError">#C03030</Color>
    <Color x:Key="BorderChipOn">#22C55E</Color>
    <Color x:Key="BorderChipOff">#003B46</Color>
    <Color x:Key="BorderChipOnFolder">#F59E0B</Color>
    <Color x:Key="BorderChipOnPattern">#FF7070</Color>
    <Color x:Key="BorderChunkDefault">#006770</Color>
    <Color x:Key="BorderChunkCopied">#008C8B</Color>
    <Color x:Key="BorderChunkSelected">#F59E0B</Color>
    <Color x:Key="BorderPreview">#003B46</Color>
    <Color x:Key="BorderPrompt">#006770</Color>

    <!-- Slider -->
    <Color x:Key="SliderTrackActive">#F59E0B</Color>
    <Color x:Key="SliderTrackInactive">#070F12</Color>
    <Color x:Key="SliderThumb">#FCD34D</Color>
    <Color x:Key="ActivityIndicatorColor">#F59E0B</Color>

    <!-- ══════════════════════════════════════════════════════════════════════
         CONVERTERS
         ══════════════════════════════════════════════════════════════════════ -->
    <!-- File-type chip (green when on) -->
    <conv:BoolToColorConverter x:Key="ChipBorderConv"
                               TrueColor="{StaticResource BorderChipOn}"
                               FalseColor="{StaticResource BorderChipOff}" />
    <conv:BoolToColorConverter x:Key="ChipBgConv"
                               TrueColor="{StaticResource BgChipOn}"
                               FalseColor="{StaticResource BgChipOff}" />

    <!-- Folder chip (violet when excluded) -->
    <conv:BoolToColorConverter x:Key="FolderChipBorderConv"
                               TrueColor="{StaticResource BorderChipOnFolder}"
                               FalseColor="{StaticResource BorderChipOff}" />
    <conv:BoolToColorConverter x:Key="FolderChipBgConv"
                               TrueColor="{StaticResource BgChipOnFolder}"
                               FalseColor="{StaticResource BgChipOff}" />

    <!-- Pattern chip (red when on) -->
    <conv:BoolToColorConverter x:Key="PatternChipBorderConv"
                               TrueColor="{StaticResource BorderChipOnPattern}"
                               FalseColor="{StaticResource BorderChipOff}" />
    <conv:BoolToColorConverter x:Key="PatternChipBgConv"
                               TrueColor="{StaticResource BgChipOnPattern}"
                               FalseColor="{StaticResource BgChipOff}" />

    <!-- Chip label color -->
    <conv:BoolToColorConverter x:Key="ChipLabelColorConv"
                               TrueColor="{StaticResource TextPrimary}"
                               FalseColor="{StaticResource TextMuted}" />

    <!-- Selection indicator -->
    <conv:BoolToColorConverter x:Key="SelectionDotBgConv"
                               TrueColor="{StaticResource AccentPrimary}"
                               FalseColor="Transparent" />
    <conv:BoolToColorConverter x:Key="SelectionDotBorderConv"
                               TrueColor="{StaticResource AccentPrimary}"
                               FalseColor="{StaticResource BorderDefault}" />

    <!-- Share-select indicator -->
    <conv:BoolToColorConverter x:Key="ShareSelectDotBgConv"
                               TrueColor="{StaticResource AccentPrimary}"
                               FalseColor="Transparent" />
    <conv:BoolToColorConverter x:Key="ShareSelectDotBorderConv"
                               TrueColor="{StaticResource AccentPrimary}"
                               FalseColor="{StaticResource BorderDefault}" />

    <!-- General utils -->
    <conv:InverseBoolConverter        x:Key="InverseBool" />
    <conv:IntGreaterThanZeroConverter x:Key="IntGtZero" />
    <conv:BoolToStringConverter x:Key="ExpandArrowConv"   TrueValue="▲" FalseValue="▼" />
    <conv:BoolToStringConverter x:Key="SelectionHintConv" TrueValue=""  FalseValue="tap cards to select" />

    <!-- ══════════════════════════════════════════════════════════════════════
         GLOBAL DEFAULTS
         ══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource BgApp}" />
    </Style>
    <Style TargetType="Label">
        <Setter Property="TextColor"  Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
    </Style>
    <Style TargetType="Entry">
        <Setter Property="TextColor"        Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontFamily"       Value="OpenSansRegular" />
        <Setter Property="BackgroundColor"  Value="Transparent" />
    </Style>
    <Style TargetType="Editor">
        <Setter Property="TextColor"        Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontFamily"       Value="OpenSansRegular" />
        <Setter Property="BackgroundColor"  Value="Transparent" />
    </Style>
    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         CARDS
         ══════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgCard}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource BorderDefault}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 14" />
        <Setter Property="Padding"         Value="14" />
        <Setter Property="Margin"          Value="0,0,0,10" />
    </Style>

    <Style x:Key="HeaderCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentPrimaryLight}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource AccentPrimary}" />
        <Setter Property="StrokeShape"     Value="Rectangle 14" />
        <Setter Property="Padding"         Value="14" />
        <Setter Property="Margin"          Value="0,0,0,10" />
    </Style>

    <Style x:Key="CompactHeaderCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgCard}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource AccentPrimaryBorder}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 14" />
        <Setter Property="Padding"         Value="14,10" />
        <Setter Property="Margin"          Value="0,0,0,10" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         INPUTS
         ══════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="InputBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgInput}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource BorderInput}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 10" />
        <Setter Property="Padding"         Value="0" />
    </Style>

    <Style x:Key="InputEntry" TargetType="Entry">
        <Setter Property="TextColor"        Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize"         Value="14" />
        <Setter Property="HeightRequest"    Value="50" />
        <Setter Property="Margin"           Value="12,0" />
        <Setter Property="BackgroundColor"  Value="Transparent" />
    </Style>

    <Style x:Key="InlineEditor" TargetType="Editor">
        <Setter Property="TextColor"            Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor"     Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize"             Value="13" />
        <Setter Property="BackgroundColor"      Value="{StaticResource BgPromptEdit}" />
        <Setter Property="Margin"               Value="0,4,0,4" />
        <Setter Property="MinimumHeightRequest" Value="120" />
    </Style>

    <Style x:Key="BranchPickerLabel" TargetType="Label">
        <Setter Property="TextColor"     Value="{StaticResource TextPrimary}" />
        <Setter Property="FontSize"      Value="14" />
        <Setter Property="FontFamily"    Value="OpenSansRegular" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
        <Setter Property="MaxLines"      Value="1" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         TYPOGRAPHY
         ══════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="SectionTitle" TargetType="Label">
        <Setter Property="TextColor"        Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize"         Value="11" />
        <Setter Property="FontAttributes"   Value="Bold" />
        <Setter Property="CharacterSpacing" Value="1.5" />
        <Setter Property="Margin"           Value="0,0,0,10" />
    </Style>

    <Style x:Key="FieldLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize"  Value="12" />
        <Setter Property="Margin"    Value="0,0,0,4" />
    </Style>

    <Style x:Key="HeaderTitle" TargetType="Label">
        <Setter Property="TextColor"      Value="{StaticResource AccentPrimaryLight}" />
        <Setter Property="FontSize"       Value="26" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontFamily"     Value="OpenSansSemibold" />
    </Style>

    <Style x:Key="HeaderSubtitle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize"  Value="12" />
    </Style>

    <Style x:Key="CompactSummaryLabel" TargetType="Label">
        <Setter Property="TextColor"      Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize"       Value="13" />
        <Setter Property="LineBreakMode"  Value="TailTruncation" />
        <Setter Property="MaxLines"       Value="1" />
    </Style>

    <Style x:Key="HintLabel" TargetType="Label">
        <Setter Property="TextColor"     Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize"      Value="11" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
        <Setter Property="Margin"        Value="0,0,0,8" />
    </Style>

    <Style x:Key="SliderWarningLabel" TargetType="Label">
        <Setter Property="FontSize"      Value="12" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
        <Setter Property="Margin"        Value="0,0,0,10" />
    </Style>

    <Style x:Key="MonospaceLabel" TargetType="Label">
        <Setter Property="FontFamily"    Value="Courier New, Courier, monospace" />
        <Setter Property="FontSize"      Value="11" />
        <Setter Property="TextColor"     Value="{StaticResource TextCode}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!--
         FILE TYPE CARD SUMMARY
         Single-line accent-colored label visible when the FILE TYPES card
         is collapsed. Shows enabled extensions + optional file count,
         e.g. ".cs  .xaml  .json  ·  47 files"
    -->
    <Style x:Key="FileTypeSummaryLabel" TargetType="Label">
        <Setter Property="TextColor"     Value="{StaticResource AccentPrimaryLight}" />
        <Setter Property="FontSize"      Value="12" />
        <Setter Property="FontFamily"    Value="OpenSansSemibold" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
        <Setter Property="MaxLines"      Value="1" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         BUTTONS
         ══════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="PrimaryBtn" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="{StaticResource AccentPrimary}" />
        <Setter Property="TextColor"            Value="{StaticResource TextOnAccent}" />
        <Setter Property="FontSize"             Value="17" />
        <Setter Property="FontAttributes"       Value="Bold" />
        <Setter Property="FontFamily"           Value="OpenSansSemibold" />
        <Setter Property="CornerRadius"         Value="14" />
        <Setter Property="MinimumHeightRequest" Value="58" />
        <Setter Property="Padding"              Value="16,0" />
    </Style>

    <Style x:Key="SecondaryBtn" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="{StaticResource BgCard}" />
        <Setter Property="TextColor"            Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize"             Value="15" />
        <Setter Property="FontFamily"           Value="OpenSansSemibold" />
        <Setter Property="CornerRadius"         Value="14" />
        <Setter Property="MinimumHeightRequest" Value="50" />
        <Setter Property="Padding"              Value="12,0" />
        <Setter Property="BorderColor"          Value="{StaticResource BorderDefault}" />
        <Setter Property="BorderWidth"          Value="1" />
    </Style>

    <Style x:Key="IconBtn" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="Transparent" />
        <Setter Property="TextColor"            Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize"             Value="18" />
        <Setter Property="Padding"              Value="8,0" />
        <Setter Property="MinimumHeightRequest" Value="50" />
        <Setter Property="MinimumWidthRequest"  Value="44" />
    </Style>

    <Style x:Key="SmallIconBtn" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="Transparent" />
        <Setter Property="TextColor"            Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize"             Value="13" />
        <Setter Property="Padding"              Value="6,0" />
        <Setter Property="MinimumHeightRequest" Value="40" />
        <Setter Property="MinimumWidthRequest"  Value="36" />
    </Style>

    <!--
         TOGGLE ALL BUTTON
         Used in chip-filter section headers (File Types, Folders, Patterns).
    -->
    <Style x:Key="ToggleAllBtn" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="{StaticResource AccentPrimaryBg}" />
        <Setter Property="TextColor"            Value="{StaticResource AccentPrimaryLight}" />
        <Setter Property="FontSize"             Value="11" />
        <Setter Property="FontAttributes"       Value="Bold" />
        <Setter Property="CornerRadius"         Value="8" />
        <Setter Property="Padding"              Value="10,4" />
        <Setter Property="MinimumHeightRequest" Value="32" />
        <Setter Property="BorderColor"          Value="{StaticResource AccentPrimaryBorder}" />
        <Setter Property="BorderWidth"          Value="1" />
    </Style>

    <!--
         AUTO-DETECT BUTTON
         Teal variant of ToggleAllBtn. Shown in the FILE TYPES header only when
         the entered URL is a GitHub URL.
    -->
    <Style x:Key="AutoDetectBtn" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="{StaticResource AccentSecondBg}" />
        <Setter Property="TextColor"            Value="{StaticResource AccentSecond}" />
        <Setter Property="FontSize"             Value="11" />
        <Setter Property="FontAttributes"       Value="Bold" />
        <Setter Property="CornerRadius"         Value="8" />
        <Setter Property="Padding"              Value="10,4" />
        <Setter Property="MinimumHeightRequest" Value="32" />
        <Setter Property="BorderColor"          Value="{StaticResource AccentSecondBorder}" />
        <Setter Property="BorderWidth"          Value="1" />
    </Style>

    <!--
         SLIDER PRESET BUTTONS
         Small pill buttons above the token slider (4K / 8K / 16K / 32K).
    -->
    <Style x:Key="SliderPresetBtn" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="{StaticResource BgInput}" />
        <Setter Property="TextColor"            Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize"             Value="12" />
        <Setter Property="FontFamily"           Value="OpenSansSemibold" />
        <Setter Property="CornerRadius"         Value="8" />
        <Setter Property="Padding"              Value="0,0" />
        <Setter Property="MinimumHeightRequest" Value="34" />
        <Setter Property="BorderColor"          Value="{StaticResource BorderDefault}" />
        <Setter Property="BorderWidth"          Value="1" />
    </Style>

    <Style x:Key="ChunkActionBtn" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="Transparent" />
        <Setter Property="TextColor"            Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize"             Value="15" />
        <Setter Property="Padding"              Value="8,4" />
        <Setter Property="MinimumHeightRequest" Value="40" />
        <Setter Property="MinimumWidthRequest"  Value="38" />
    </Style>

    <Style x:Key="ShareBtn" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="{StaticResource AccentPrimary}" />
        <Setter Property="TextColor"            Value="{StaticResource TextOnAccent}" />
        <Setter Property="FontSize"             Value="14" />
        <Setter Property="FontAttributes"       Value="Bold" />
        <Setter Property="FontFamily"           Value="OpenSansSemibold" />
        <Setter Property="CornerRadius"         Value="10" />
        <Setter Property="MinimumHeightRequest" Value="42" />
        <Setter Property="Padding"              Value="16,0" />
    </Style>

    <Style x:Key="CopySelectedBtn" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="{StaticResource AccentSecondBg}" />
        <Setter Property="TextColor"            Value="{StaticResource AccentSecond}" />
        <Setter Property="FontSize"             Value="14" />
        <Setter Property="FontAttributes"       Value="Bold" />
        <Setter Property="FontFamily"           Value="OpenSansSemibold" />
        <Setter Property="CornerRadius"         Value="10" />
        <Setter Property="MinimumHeightRequest" Value="42" />
        <Setter Property="Padding"              Value="16,0" />
        <Setter Property="BorderColor"          Value="{StaticResource AccentSecondBorder}" />
        <Setter Property="BorderWidth"          Value="1" />
    </Style>

    <Style x:Key="BackBtn" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="{StaticResource BgCard}" />
        <Setter Property="TextColor"            Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize"             Value="14" />
        <Setter Property="FontFamily"           Value="OpenSansSemibold" />
        <Setter Property="CornerRadius"         Value="10" />
        <Setter Property="MinimumHeightRequest" Value="46" />
        <Setter Property="Padding"              Value="16,0" />
        <Setter Property="BorderColor"          Value="{StaticResource BorderDefault}" />
        <Setter Property="BorderWidth"          Value="1" />
    </Style>

    <Style x:Key="PromptSaveBtn" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="{StaticResource AccentSecondBg}" />
        <Setter Property="TextColor"            Value="{StaticResource AccentSecond}" />
        <Setter Property="FontSize"             Value="12" />
        <Setter Property="CornerRadius"         Value="8" />
        <Setter Property="Padding"              Value="12,4" />
        <Setter Property="MinimumHeightRequest" Value="34" />
        <Setter Property="BorderColor"          Value="{StaticResource AccentSecondBorder}" />
        <Setter Property="BorderWidth"          Value="1" />
    </Style>

    <Style x:Key="PromptDeleteBtn" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="Transparent" />
        <Setter Property="TextColor"            Value="{StaticResource TextError}" />
        <Setter Property="FontSize"             Value="12" />
        <Setter Property="CornerRadius"         Value="8" />
        <Setter Property="Padding"              Value="8,4" />
        <Setter Property="MinimumHeightRequest" Value="34" />
    </Style>

    <!--
         RESET PROMPTS BUTTON
         Destructive secondary action — red border, dark background.
    -->
    <Style x:Key="ResetPromptsBtn" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="{StaticResource BgCard}" />
        <Setter Property="TextColor"            Value="{StaticResource AccentRed}" />
        <Setter Property="FontSize"             Value="13" />
        <Setter Property="FontFamily"           Value="OpenSansSemibold" />
        <Setter Property="CornerRadius"         Value="10" />
        <Setter Property="MinimumHeightRequest" Value="42" />
        <Setter Property="Padding"              Value="12,0" />
        <Setter Property="BorderColor"          Value="{StaticResource AccentRed}" />
        <Setter Property="BorderWidth"          Value="1" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         SMART ACTION BAR (fixed bottom)
         ══════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="SmartActionBarBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgSmartBar}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource BgSmartBar}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 0" />
        <Setter Property="Padding"         Value="14,10,14,14" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         CHIPS
         ══════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="ChipBorder" TargetType="Border">
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 8" />
        <Setter Property="Padding"         Value="14,9" />
        <Setter Property="Margin"          Value="0,0,6,6" />
    </Style>

    <Style x:Key="ChipLabel" TargetType="Label">
        <Setter Property="FontSize"        Value="13" />
        <Setter Property="FontAttributes"  Value="Bold" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         CUSTOM SELECTION INDICATOR
         ══════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="SelectionDot" TargetType="Border">
        <Setter Property="WidthRequest"    Value="22" />
        <Setter Property="HeightRequest"   Value="22" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 11" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="Margin"          Value="0,0,6,0" />
        <Setter Property="Padding"         Value="0" />
    </Style>

    <Style x:Key="SelectionDotCheck" TargetType="Label">
        <Setter Property="Text"                    Value="✓" />
        <Setter Property="TextColor"               Value="{StaticResource TextOnAccent}" />
        <Setter Property="FontSize"                Value="11" />
        <Setter Property="FontAttributes"          Value="Bold" />
        <Setter Property="HorizontalOptions"       Value="Center" />
        <Setter Property="VerticalOptions"         Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="VerticalTextAlignment"   Value="Center" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         SAVED REPOS LIST
         ══════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="SavedReposListBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgInput}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource BorderInput}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 10" />
        <Setter Property="Padding"         Value="0" />
    </Style>

    <Style x:Key="SavedRepoRowLabel" TargetType="Label">
        <Setter Property="TextColor"     Value="{StaticResource TextPrimary}" />
        <Setter Property="FontSize"      Value="14" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
        <Setter Property="MaxLines"      Value="1" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         SELECTION TOOLBAR
         ══════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="SelectionToolbarBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgSelectionToolbar}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource BorderSelectionToolbar}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 12" />
        <Setter Property="Padding"         Value="14,10" />
        <Setter Property="Margin"          Value="0,0,0,10" />
    </Style>

    <Style x:Key="SelectionCountLabel" TargetType="Label">
        <Setter Property="TextColor"      Value="{StaticResource AccentPrimaryLight}" />
        <Setter Property="FontSize"       Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontFamily"     Value="OpenSansSemibold" />
    </Style>

    <Style x:Key="SelectionTokensLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize"  Value="11" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         PREVIEW PANEL (chunk file list)
         ══════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="PreviewBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgPreview}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 0,0,14,14" />
        <Setter Property="Padding"         Value="14,10,14,14" />
    </Style>

    <Style x:Key="PreviewLabel" TargetType="Label">
        <Setter Property="TextColor"     Value="{StaticResource TextCode}" />
        <Setter Property="FontSize"      Value="11" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
        <Setter Property="FontFamily"    Value="Courier New, Courier, monospace" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         PROMPT FULL-TEXT PREVIEW PANEL
         Mirrors PreviewBorder / PreviewLabel but slightly larger text so
         the prompt prose is comfortable to read.
         ══════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="PromptPreviewBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgPromptEdit}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 0,0,12,12" />
        <Setter Property="Padding"         Value="14,10,14,14" />
    </Style>

    <Style x:Key="PromptPreviewLabel" TargetType="Label">
        <Setter Property="TextColor"     Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize"      Value="12" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         CHUNK CARDS
         ══════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="ChunkBorder" TargetType="Border">
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 12" />
        <Setter Property="Padding"         Value="0" />
        <Setter Property="Margin"          Value="0,0,0,6" />
    </Style>

    <Style x:Key="ChunkTitleLabel" TargetType="Label">
        <Setter Property="TextColor"      Value="{StaticResource TextPrimary}" />
        <Setter Property="FontSize"       Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontFamily"     Value="OpenSansSemibold" />
        <Setter Property="LineBreakMode"  Value="TailTruncation" />
    </Style>

    <Style x:Key="ChunkSubLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize"  Value="12" />
        <Setter Property="Margin"    Value="0,2,0,0" />
    </Style>

    <!-- "✓ Copied" badge on chunk cards -->
    <Style x:Key="CopiedBadgeBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentSecondBg}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource AccentSecondBorder}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 6" />
        <Setter Property="Padding"         Value="8,3" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style x:Key="CopiedBadgeLabel" TargetType="Label">
        <Setter Property="Text"           Value="✓ Copied" />
        <Setter Property="TextColor"      Value="{StaticResource AccentSecond}" />
        <Setter Property="FontSize"       Value="11" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         PROMPT CARDS
         ══════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="PromptCardBorder" TargetType="Border">
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 12" />
        <Setter Property="Padding"         Value="0" />
        <Setter Property="Margin"          Value="0,0,0,8" />
    </Style>

    <Style x:Key="PromptTitleLabel" TargetType="Label">
        <Setter Property="TextColor"      Value="{StaticResource AccentPrimaryLight}" />
        <Setter Property="FontSize"       Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontFamily"     Value="OpenSansSemibold" />
    </Style>

    <Style x:Key="PromptPreviewLabel2" TargetType="Label">
        <Setter Property="TextColor"     Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize"      Value="12" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
        <Setter Property="MaxLines"      Value="2" />
        <Setter Property="Margin"        Value="0,4,0,0" />
    </Style>

    <Style x:Key="PromptEditBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgPromptEdit}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 0,0,12,12" />
        <Setter Property="Padding"         Value="12,10,12,14" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         SUMMARY STATS
         ══════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="StatNumberLabel" TargetType="Label">
        <Setter Property="TextColor"         Value="{StaticResource AccentSecond}" />
        <Setter Property="FontSize"          Value="22" />
        <Setter Property="FontAttributes"    Value="Bold" />
        <Setter Property="FontFamily"        Value="OpenSansSemibold" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <Style x:Key="StatCaptionLabel" TargetType="Label">
        <Setter Property="TextColor"         Value="{StaticResource TextGreen}" />
        <Setter Property="FontSize"          Value="11" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         STATUS / ERROR
         ══════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="StatusBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgStatus}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource BorderDefault}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 10" />
        <Setter Property="Padding"         Value="14,10" />
        <Setter Property="Margin"          Value="0,0,0,10" />
    </Style>

    <Style x:Key="StatusLabel" TargetType="Label">
        <Setter Property="TextColor"               Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize"                Value="13" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="LineBreakMode"           Value="WordWrap" />
    </Style>

    <Style x:Key="ErrorBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgError}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource BorderError}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 10" />
        <Setter Property="Padding"         Value="14,10" />
        <Setter Property="Margin"          Value="0,0,0,10" />
    </Style>

    <Style x:Key="ErrorLabel" TargetType="Label">
        <Setter Property="TextColor"     Value="{StaticResource TextError}" />
        <Setter Property="FontSize"      Value="13" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         TOKEN BADGE
         ══════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="TokenBadgeBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentPrimaryBg}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource AccentPrimaryBorder}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 8" />
        <Setter Property="Padding"         Value="12,6" />
    </Style>

    <Style x:Key="TokenBadgeLabel" TargetType="Label">
        <Setter Property="TextColor"      Value="{StaticResource AccentPrimaryLight}" />
        <Setter Property="FontSize"       Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontFamily"     Value="OpenSansSemibold" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         SUMMARY CARD  (success box after chunk run)
         ══════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="SummaryBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgSuccess}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource BorderSuccess}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 12" />
        <Setter Property="Padding"         Value="12" />
        <Setter Property="Margin"          Value="0,0,0,14" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         SAVED TOKEN INDICATOR
         ══════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="SavedTokenBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentSecondBg}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource AccentSecondBorder}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 6" />
        <Setter Property="Padding"         Value="8,4" />
    </Style>

</ResourceDictionary>
