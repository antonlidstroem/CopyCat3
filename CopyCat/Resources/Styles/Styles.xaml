<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:conv="clr-namespace:CopyCat.Converters"
                    x:Class="CopyCat.Resources.Styles.Styles">

    <!-- ══════════════════════════════════════════════════════════
         COLORS
         ══════════════════════════════════════════════════════════ -->

    <Color x:Key="BgApp">#111118</Color>
    <Color x:Key="BgCard">#1C1C28</Color>
    <Color x:Key="BgInput">#0D0D16</Color>
    <Color x:Key="BgStatus">#14141F</Color>
    <Color x:Key="BgSuccess">#0A1A12</Color>
    <Color x:Key="BgError">#200A0A</Color>
    <Color x:Key="BgChipOn">#1A2E1A</Color>
    <Color x:Key="BgChipOff">#13131F</Color>
    <Color x:Key="BgChunkDefault">#1A1A2E</Color>
    <Color x:Key="BgChunkCopied">#1A2E20</Color>
    <Color x:Key="BgChunkSelected">#17213A</Color>
    <Color x:Key="BgPreview">#0D0D18</Color>

    <Color x:Key="AccentPrimary">#5B8EFF</Color>
    <Color x:Key="AccentPrimaryLight">#7BACFF</Color>
    <Color x:Key="AccentPrimaryBg">#1A5B8EFF</Color>
    <Color x:Key="AccentPrimaryBorder">#445B8EFF</Color>
    <Color x:Key="AccentGreen">#22C55E</Color>
    <Color x:Key="AccentGreenBg">#3322C55E</Color>
    <Color x:Key="AccentGreenBorder">#3322C55E</Color>

    <Color x:Key="BgSelectionToolbar">#1A2240</Color>
    <Color x:Key="BorderSelectionToolbar">#5B8EFF</Color>

    <Color x:Key="TextPrimary">#E0E0FF</Color>
    <Color x:Key="TextSecondary">#A0A0C0</Color>
    <Color x:Key="TextMuted">#666690</Color>
    <Color x:Key="TextDim">#404060</Color>
    <Color x:Key="TextGreen">#2A7048</Color>
    <Color x:Key="TextError">#FF7070</Color>
    <Color x:Key="TextAccent">#7BACFF</Color>
    <Color x:Key="TextOnAccent">#FFFFFF</Color>
    <Color x:Key="TextCode">#B0C4FF</Color>

    <Color x:Key="BorderDefault">#2D2D4A</Color>
    <Color x:Key="BorderInput">#3D3D60</Color>
    <Color x:Key="BorderSuccess">#3322C55E</Color>
    <Color x:Key="BorderError">#C03030</Color>
    <Color x:Key="BorderChipOn">#22C55E</Color>
    <Color x:Key="BorderChipOff">#2D2D4A</Color>
    <Color x:Key="BorderChunkDefault">#2D2D4A</Color>
    <Color x:Key="BorderChunkCopied">#22C55E</Color>
    <Color x:Key="BorderChunkSelected">#5B8EFF</Color>
    <Color x:Key="BorderPreview">#1E1E35</Color>

    <Color x:Key="SliderTrackActive">#5B8EFF</Color>
    <Color x:Key="SliderTrackInactive">#2D2D4A</Color>
    <Color x:Key="SliderThumb">#7BACFF</Color>
    <Color x:Key="ActivityIndicatorColor">#5B8EFF</Color>

    <!-- ══════════════════════════════════════════════════════════
         CONVERTERS
         ══════════════════════════════════════════════════════════ -->

    <conv:BoolToColorConverter x:Key="ChipBorderConv"
                               TrueColor="{StaticResource BorderChipOn}"
                               FalseColor="{StaticResource BorderChipOff}" />
    <conv:BoolToColorConverter x:Key="ChipBgConv"
                               TrueColor="{StaticResource BgChipOn}"
                               FalseColor="{StaticResource BgChipOff}" />

    <conv:BoolToColorConverter x:Key="ChunkBorderConv"
                               TrueColor="{StaticResource BorderChunkCopied}"
                               FalseColor="{StaticResource BorderChunkDefault}" />
    <conv:BoolToColorConverter x:Key="ChunkBgConv"
                               TrueColor="{StaticResource BgChunkCopied}"
                               FalseColor="{StaticResource BgChunkDefault}" />

    <!-- Multi-select: blå border/bakgrund när IsSelected=true -->
    <conv:BoolToColorConverter x:Key="ChunkSelectedBorderConv"
                               TrueColor="{StaticResource BorderChunkSelected}"
                               FalseColor="{StaticResource BorderChunkDefault}" />
    <conv:BoolToColorConverter x:Key="ChunkSelectedBgConv"
                               TrueColor="{StaticResource BgChunkSelected}"
                               FalseColor="{StaticResource BgChunkDefault}" />

    <conv:InverseBoolConverter        x:Key="InverseBool" />
    <conv:IntGreaterThanZeroConverter  x:Key="IntGtZero" />
    <conv:BoolToStringConverter        x:Key="ExpandArrowConv"
                                       TrueValue="▲"
                                       FalseValue="▼" />

    <!-- Instruktionstext bredvid CHUNKS-rubriken -->
    <conv:BoolToStringConverter        x:Key="SelectionHintConv"
                                       TrueValue=""
                                       FalseValue="kryssa för att markera" />

    <!-- ══════════════════════════════════════════════════════════
         GLOBAL ELEMENT DEFAULTS
         ══════════════════════════════════════════════════════════ -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource BgApp}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor"  Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor"        Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontFamily"       Value="OpenSansRegular" />
        <Setter Property="BackgroundColor"  Value="Transparent" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Color" Value="{StaticResource AccentPrimary}" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         LAYOUT CARDS
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgCard}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource BorderDefault}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 14" />
        <Setter Property="Padding"         Value="14" />
        <Setter Property="Margin"          Value="0,0,0,10" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         INPUT FIELDS
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="InputBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgInput}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource BorderInput}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 10" />
        <Setter Property="Padding"         Value="0" />
    </Style>

    <Style x:Key="InputEntry" TargetType="Entry">
        <Setter Property="TextColor"        Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize"         Value="14" />
        <Setter Property="HeightRequest"    Value="50" />
        <Setter Property="Margin"           Value="12,0" />
        <Setter Property="BackgroundColor"  Value="Transparent" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         TYPOGRAPHY
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="SectionTitle" TargetType="Label">
        <Setter Property="TextColor"        Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize"         Value="11" />
        <Setter Property="FontAttributes"   Value="Bold" />
        <Setter Property="CharacterSpacing" Value="1.5" />
        <Setter Property="Margin"           Value="0,0,0,10" />
    </Style>

    <Style x:Key="FieldLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize"  Value="12" />
        <Setter Property="Margin"    Value="0,0,0,4" />
    </Style>

    <Style x:Key="HeaderTitle" TargetType="Label">
        <Setter Property="TextColor"      Value="{StaticResource AccentPrimaryLight}" />
        <Setter Property="FontSize"       Value="26" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontFamily"     Value="OpenSansSemibold" />
    </Style>

    <Style x:Key="HeaderSubtitle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize"  Value="12" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         BUTTONS
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="PrimaryBtn" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="{StaticResource AccentPrimary}" />
        <Setter Property="TextColor"            Value="{StaticResource TextOnAccent}" />
        <Setter Property="FontSize"             Value="17" />
        <Setter Property="FontAttributes"       Value="Bold" />
        <Setter Property="FontFamily"           Value="OpenSansSemibold" />
        <Setter Property="CornerRadius"         Value="14" />
        <Setter Property="MinimumHeightRequest" Value="58" />
        <Setter Property="Padding"              Value="16,0" />
    </Style>

    <Style x:Key="SecondaryBtn" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="{StaticResource BgCard}" />
        <Setter Property="TextColor"            Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize"             Value="15" />
        <Setter Property="FontFamily"           Value="OpenSansSemibold" />
        <Setter Property="CornerRadius"         Value="14" />
        <Setter Property="MinimumHeightRequest" Value="50" />
        <Setter Property="Padding"              Value="12,0" />
        <Setter Property="BorderColor"          Value="{StaticResource BorderDefault}" />
        <Setter Property="BorderWidth"          Value="1" />
    </Style>

    <Style x:Key="IconBtn" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="Transparent" />
        <Setter Property="TextColor"            Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize"             Value="18" />
        <Setter Property="Padding"              Value="8,0" />
        <Setter Property="MinimumHeightRequest" Value="50" />
        <Setter Property="MinimumWidthRequest"  Value="44" />
    </Style>

    <!-- Dela + förhandsvisnings-knappar inuti varje chunk-kort -->
    <Style x:Key="ChunkActionBtn" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="Transparent" />
        <Setter Property="TextColor"            Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize"             Value="16" />
        <Setter Property="Padding"              Value="6,4" />
        <Setter Property="MinimumHeightRequest" Value="36" />
        <Setter Property="MinimumWidthRequest"  Value="36" />
    </Style>

    <!-- Dela-knappen i multi-select toolbar -->
    <Style x:Key="ShareBtn" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="{StaticResource AccentPrimary}" />
        <Setter Property="TextColor"            Value="{StaticResource TextOnAccent}" />
        <Setter Property="FontSize"             Value="14" />
        <Setter Property="FontAttributes"       Value="Bold" />
        <Setter Property="FontFamily"           Value="OpenSansSemibold" />
        <Setter Property="CornerRadius"         Value="10" />
        <Setter Property="MinimumHeightRequest" Value="42" />
        <Setter Property="Padding"              Value="16,0" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         MULTI-SELECT TOOLBAR
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="SelectionToolbarBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgSelectionToolbar}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource BorderSelectionToolbar}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 12" />
        <Setter Property="Padding"         Value="14,10" />
        <Setter Property="Margin"          Value="0,0,0,10" />
    </Style>

    <Style x:Key="SelectionCountLabel" TargetType="Label">
        <Setter Property="TextColor"      Value="{StaticResource AccentPrimaryLight}" />
        <Setter Property="FontSize"       Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontFamily"     Value="OpenSansSemibold" />
    </Style>

    <Style x:Key="SelectionTokensLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize"  Value="11" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         FÖRHANDSVISNING (expanderbar)
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="PreviewBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgPreview}" />
        <Setter Property="StrokeThickness" Value="0" />
        <!-- Ingen top-border radius — visas direkt under huvud-raden -->
        <Setter Property="StrokeShape"     Value="RoundRectangle 0,0,14,14" />
        <Setter Property="Padding"         Value="14,10,14,14" />
    </Style>

    <Style x:Key="PreviewLabel" TargetType="Label">
        <Setter Property="TextColor"     Value="{StaticResource TextCode}" />
        <Setter Property="FontSize"      Value="11" />
        <Setter Property="FontFamily"    Value="OpenSansRegular" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         CHIPS
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="ChipBorder" TargetType="Border">
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 8" />
        <Setter Property="Padding"         Value="10,8" />
        <Setter Property="Margin"          Value="0,0,6,6" />
    </Style>

    <Style x:Key="ChipLabel" TargetType="Label">
        <Setter Property="TextColor"       Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize"        Value="13" />
        <Setter Property="FontAttributes"  Value="Bold" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         RECENT URLS
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="RecentUrlBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgInput}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource BorderInput}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 8" />
        <Setter Property="Padding"         Value="10,6" />
        <Setter Property="Margin"          Value="0,0,6,0" />
    </Style>

    <Style x:Key="RecentUrlLabel" TargetType="Label">
        <Setter Property="TextColor"     Value="{StaticResource TextAccent}" />
        <Setter Property="FontSize"      Value="12" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
        <Setter Property="MaxLines"      Value="1" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         CHUNK CARDS
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="ChunkBorder" TargetType="Border">
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 14" />
        <Setter Property="Padding"         Value="0" />
        <Setter Property="Margin"          Value="0,0,0,8" />
    </Style>

    <Style x:Key="ChunkTitleLabel" TargetType="Label">
        <Setter Property="TextColor"      Value="{StaticResource TextPrimary}" />
        <Setter Property="FontSize"       Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontFamily"     Value="OpenSansSemibold" />
        <Setter Property="LineBreakMode"  Value="TailTruncation" />
    </Style>

    <Style x:Key="ChunkSubLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize"  Value="12" />
        <Setter Property="Margin"    Value="0,2,0,0" />
    </Style>

    <Style x:Key="ChunkCheckLabel" TargetType="Label">
        <Setter Property="TextColor"       Value="{StaticResource AccentGreen}" />
        <Setter Property="FontSize"        Value="22" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="Margin"          Value="4,0,0,0" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         SUMMARY STATS
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="StatNumberLabel" TargetType="Label">
        <Setter Property="TextColor"         Value="{StaticResource AccentGreen}" />
        <Setter Property="FontSize"          Value="22" />
        <Setter Property="FontAttributes"    Value="Bold" />
        <Setter Property="FontFamily"        Value="OpenSansSemibold" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <Style x:Key="StatCaptionLabel" TargetType="Label">
        <Setter Property="TextColor"         Value="{StaticResource TextGreen}" />
        <Setter Property="FontSize"          Value="11" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         STATUS / ERROR
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="StatusBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgStatus}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource BorderDefault}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 10" />
        <Setter Property="Padding"         Value="14,10" />
        <Setter Property="Margin"          Value="0,0,0,10" />
    </Style>

    <Style x:Key="StatusLabel" TargetType="Label">
        <Setter Property="TextColor"               Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize"                Value="13" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="LineBreakMode"           Value="WordWrap" />
    </Style>

    <Style x:Key="ErrorBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgError}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource BorderError}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 10" />
        <Setter Property="Padding"         Value="14,10" />
        <Setter Property="Margin"          Value="0,0,0,10" />
    </Style>

    <Style x:Key="ErrorLabel" TargetType="Label">
        <Setter Property="TextColor"     Value="{StaticResource TextError}" />
        <Setter Property="FontSize"      Value="13" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         TOKEN BADGE
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="TokenBadgeBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentPrimaryBg}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource AccentPrimaryBorder}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 8" />
        <Setter Property="Padding"         Value="12,6" />
    </Style>

    <Style x:Key="TokenBadgeLabel" TargetType="Label">
        <Setter Property="TextColor"      Value="{StaticResource AccentPrimaryLight}" />
        <Setter Property="FontSize"       Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontFamily"     Value="OpenSansSemibold" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         SUMMARY CARD
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="SummaryBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgSuccess}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource BorderSuccess}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 12" />
        <Setter Property="Padding"         Value="12" />
        <Setter Property="Margin"          Value="0,0,0,14" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         SAVED TOKEN INDICATOR
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="SavedTokenBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentGreenBg}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource AccentGreenBorder}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 6" />
        <Setter Property="Padding"         Value="8,4" />
    </Style>

</ResourceDictionary>
