<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CopyCat.ViewModels"
             xmlns:models="clr-namespace:CopyCat.Models"
             x:Class="CopyCat.MainPage"
             x:DataType="vm:MainViewModel"
             x:Name="ThisPage"
             Title="CopyCat">

    <ScrollView VerticalScrollBarVisibility="Default">
        <VerticalStackLayout Padding="14,14,14,48" Spacing="0">

            <!-- ════════════════════════════════════════════════════
                 HEADER
                 ════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <Grid ColumnDefinitions="56,*" ColumnSpacing="14">
                    <Image Grid.Column="0" Source="copycat_logo.svg"
                           HeightRequest="52" WidthRequest="52" VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="CopyCat" Style="{StaticResource HeaderTitle}" />
                        <Label Text="GitHub · local path → chunks → AI"
                               Style="{StaticResource HeaderSubtitle}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════════════════════
                 REPOSITORY
                 ════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="0">
                    <Label Text="REPOSITORY" Style="{StaticResource SectionTitle}" />

                    <!-- URL entry + clear + paste -->
                    <Label Text="GitHub URL or local path" Style="{StaticResource FieldLabel}" />
                    <Border Style="{StaticResource InputBorder}" Margin="0,0,0,10">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <Entry Grid.Column="0"
                                   Style="{StaticResource InputEntry}"
                                   Text="{Binding RepoUrl}"
                                   Placeholder="https://github.com/owner/repo  or  C:\Projects\My.sln"
                                   Keyboard="Url"
                                   ReturnType="Next"
                                   IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                            <Button Grid.Column="1"
                                    Style="{StaticResource IconBtn}"
                                    Text="✕"
                                    Command="{Binding ClearUrlCommand}"
                                    ToolTipProperties.Text="Clear URL"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                            <Button Grid.Column="2"
                                    Style="{StaticResource IconBtn}"
                                    Text="📋"
                                    Command="{Binding PasteUrlCommand}"
                                    ToolTipProperties.Text="Paste from clipboard"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                        </Grid>
                    </Border>

                    <!-- ── Saved repos list ──
                         BUG FIX #3: the old BindableLayout inside a Border with
                         MaximumHeightRequest had no ScrollView, so rows beyond
                         the height cap were silently clipped.  Replaced with a
                         CollectionView (BUG FIX #10) which handles its own
                         virtualisation and responds correctly to
                         ObservableCollection changes on all platforms. -->
                    <VerticalStackLayout IsVisible="{Binding HasSavedRepos}"
                                         Spacing="0" Margin="0,0,0,10">

                        <!-- Sub-header -->
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6" Margin="0,0,0,6">
                            <Label Grid.Column="0"
                                   Text="Recent repositories"
                                   Style="{StaticResource FieldLabel}"
                                   Margin="0" VerticalOptions="Center" />
                            <!-- Rename: visible only when a repo is selected -->
                            <Button Grid.Column="1"
                                    Style="{StaticResource SmallIconBtn}"
                                    Text="✎  Rename"
                                    Command="{Binding RenameSelectedRepoCommand}"
                                    IsVisible="{Binding HasSelectedRepo}"
                                    ToolTipProperties.Text="Rename selected repository"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                            <!-- Deselect — clears selection without deleting -->
                            <Button Grid.Column="2"
                                    Style="{StaticResource SmallIconBtn}"
                                    Text="✕"
                                    Command="{Binding ClearSelectedRepoCommand}"
                                    IsVisible="{Binding HasSelectedRepo}"
                                    ToolTipProperties.Text="Deselect repository"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                        </Grid>

                        <!-- Repo rows — CollectionView gives reliable
                             dynamic-update behaviour and built-in scrolling -->
                        <Border Style="{StaticResource SavedReposListBorder}">
                            <CollectionView ItemsSource="{Binding SavedRepos}"
                                            SelectionMode="None"
                                            MaximumHeightRequest="220">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:SavedRepo">
                                        <Grid ColumnDefinitions="*,Auto"
                                              Padding="10,8">

                                            <!-- Tap label → select this repo -->
                                            <Label Grid.Column="0"
                                                   Text="{Binding DisplayName}"
                                                   Style="{StaticResource SavedRepoRowLabel}"
                                                   VerticalOptions="Center">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.SelectRepoCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Label.GestureRecognizers>
                                            </Label>

                                            <!-- Per-row delete — removes only this repo -->
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource SmallIconBtn}"
                                                    Text="🗑"
                                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.DeleteRepoCommand}"
                                                    CommandParameter="{Binding .}"
                                                    ToolTipProperties.Text="Remove this repository" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Border>
                    </VerticalStackLayout>

                    <!-- ── Branch ──
                         BUG FIX #5: a Button with ContentLayout="Left,8" only
                         repositions an *image* icon relative to text; for a
                         text-only button the property has no effect and text
                         stays centred — making it look nothing like an input.
                         Replaced with a tappable Grid + Label inside the same
                         InputBorder style used by the other fields. -->
                    <Label Text="Branch" Style="{StaticResource FieldLabel}" />
                    <Border Style="{StaticResource InputBorder}" Margin="0,0,0,10">
                        <Grid HeightRequest="50">
                            <!-- Normal state: label shows current branch name -->
                            <Grid IsVisible="{Binding IsFetchingBranches, Converter={StaticResource InverseBool}}"
                                  ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding BranchButtonLabel}"
                                       Style="{StaticResource BranchPickerLabel}"
                                       VerticalOptions="Center"
                                       Margin="12,0,0,0">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ShowBranchPickerCommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label Grid.Column="1"
                                       Text="⇅"
                                       TextColor="{StaticResource TextMuted}"
                                       FontSize="16"
                                       VerticalOptions="Center"
                                       Margin="0,0,12,0">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ShowBranchPickerCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>

                                <!-- Make the whole row tappable -->
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ShowBranchPickerCommand}" />
                                </Grid.GestureRecognizers>
                            </Grid>

                            <!-- Loading state: spinner + label -->
                            <HorizontalStackLayout IsVisible="{Binding IsFetchingBranches}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   Spacing="10">
                                <ActivityIndicator IsRunning="{Binding IsFetchingBranches}"
                                                   Color="{StaticResource AccentPrimary}"
                                                   HeightRequest="20" WidthRequest="20"
                                                   VerticalOptions="Center" />
                                <Label Text="Loading branches…"
                                       TextColor="{StaticResource TextMuted}"
                                       FontSize="13" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>

                    <!-- GitHub Token -->
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                          Margin="0,0,0,4" ColumnSpacing="6">
                        <Label Grid.Column="0"
                               Text="GitHub Token (private repos)"
                               Style="{StaticResource FieldLabel}"
                               Margin="0" VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="ⓘ"
                               TextColor="{StaticResource AccentPrimary}"
                               FontSize="16" VerticalOptions="Center" Margin="2,0,0,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ShowTokenInfoCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Border Grid.Column="3"
                                Style="{StaticResource SavedTokenBorder}"
                                IsVisible="{Binding TokenIsSaved}">
                            <Label Text="✓ Saved"
                                   TextColor="{StaticResource AccentGreen}"
                                   FontSize="11" FontAttributes="Bold" />
                        </Border>
                    </Grid>
                    <Border Style="{StaticResource InputBorder}">
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry Grid.Column="0"
                                   Style="{StaticResource InputEntry}"
                                   Text="{Binding AccessToken}"
                                   Placeholder="ghp_… (leave empty for public repos)"
                                   IsPassword="True"
                                   ReturnType="Done"
                                   IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                            <Button Grid.Column="1"
                                    Style="{StaticResource IconBtn}"
                                    Text="🗑"
                                    Command="{Binding ClearTokenCommand}"
                                    IsVisible="{Binding TokenIsSaved}"
                                    ToolTipProperties.Text="Clear saved token" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- ════════════════════════════════════════════════════
                 KEYWORD FILTER  (collapsible)
                 ════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="KEYWORD FILTER"
                               Style="{StaticResource SectionTitle}"
                               Margin="0" VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding IsKeywordExpanded, Converter={StaticResource ExpandArrowConv}}"
                               TextColor="{StaticResource TextMuted}" FontSize="12" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleKeywordCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleKeywordCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <VerticalStackLayout IsVisible="{Binding IsKeywordExpanded}" Spacing="0">
                        <Label Text="Only files whose content contains this term will be included. Leave empty to include all files."
                               Style="{StaticResource HintLabel}" />
                        <Border Style="{StaticResource InputBorder}">
                            <Grid ColumnDefinitions="*,Auto">
                                <Entry Grid.Column="0"
                                       Style="{StaticResource InputEntry}"
                                       Text="{Binding KeywordFilter}"
                                       Placeholder="e.g. OrderService, IRepository…"
                                       ReturnType="Done"
                                       IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource IconBtn}"
                                        Text="✕"
                                        Command="{Binding ClearKeywordFilterCommand}"
                                        ToolTipProperties.Text="Clear keyword"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ════════════════════════════════════════════════════
                 FILE TYPES  (collapsible + toggle all)
                 ════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="FILE TYPES"
                               Style="{StaticResource SectionTitle}"
                               Margin="0" VerticalOptions="Center" />
                        <Button Grid.Column="1"
                                Style="{StaticResource ToggleAllBtn}"
                                Text="Toggle all"
                                Command="{Binding ToggleAllFileTypesCommand}"
                                IsVisible="{Binding IsFileTypesExpanded}" />
                        <Label Grid.Column="2"
                               Text="{Binding IsFileTypesExpanded, Converter={StaticResource ExpandArrowConv}}"
                               TextColor="{StaticResource TextMuted}" FontSize="12" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleFileTypesCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleFileTypesCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start"
                                IsVisible="{Binding IsFileTypesExpanded}">
                        <BindableLayout.ItemsSource>
                            <Binding Path="FileTypeFilters" />
                        </BindableLayout.ItemsSource>
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:FileTypeFilter">
                                <Border Style="{StaticResource ChipBorder}"
                                        BackgroundColor="{Binding IsEnabled, Converter={StaticResource ChipBgConv}}"
                                        Stroke="{Binding IsEnabled, Converter={StaticResource ChipBorderConv}}">
                                    <HorizontalStackLayout Spacing="4">
                                        <CheckBox IsChecked="{Binding IsEnabled}"
                                                  Color="{StaticResource AccentPrimary}"
                                                  VerticalOptions="Center" />
                                        <Label Text="{Binding Label}" Style="{StaticResource ChipLabel}" />
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ════════════════════════════════════════════════════
                 EXCLUDE FOLDERS  (collapsible + toggle all + custom)
                 ════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="EXCLUDE FOLDERS"
                               Style="{StaticResource SectionTitle}"
                               Margin="0" VerticalOptions="Center" />
                        <Button Grid.Column="1"
                                Style="{StaticResource ToggleAllBtn}"
                                Text="Toggle all"
                                Command="{Binding ToggleAllFolderFiltersCommand}"
                                IsVisible="{Binding IsFoldersExpanded}" />
                        <Label Grid.Column="2"
                               Text="{Binding IsFoldersExpanded, Converter={StaticResource ExpandArrowConv}}"
                               TextColor="{StaticResource TextMuted}" FontSize="12" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleFoldersCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleFoldersCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start"
                                IsVisible="{Binding IsFoldersExpanded}">
                        <BindableLayout.ItemsSource>
                            <Binding Path="FolderFilters" />
                        </BindableLayout.ItemsSource>
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:FolderFilter">
                                <Border Style="{StaticResource ChipBorder}"
                                        BackgroundColor="{Binding IsExcluded, Converter={StaticResource ChipBgConv}}"
                                        Stroke="{Binding IsExcluded, Converter={StaticResource ChipBorderConv}}">
                                    <HorizontalStackLayout Spacing="4">
                                        <CheckBox IsChecked="{Binding IsExcluded}"
                                                  Color="{StaticResource AccentGreen}"
                                                  VerticalOptions="Center" />
                                        <Label Text="{Binding Name}" Style="{StaticResource ChipLabel}" />
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8"
                          IsVisible="{Binding IsFoldersExpanded}" Margin="0,6,0,0">
                        <Border Grid.Column="0" Style="{StaticResource InputBorder}">
                            <Entry Style="{StaticResource InputEntry}"
                                   Text="{Binding CustomFolderInput}"
                                   Placeholder="Add folder name…"
                                   ReturnType="Done"
                                   ReturnCommand="{Binding AddCustomFolderCommand}"
                                   IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                        </Border>
                        <Button Grid.Column="1"
                                Style="{StaticResource ToggleAllBtn}"
                                Text="+ Add"
                                Command="{Binding AddCustomFolderCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ════════════════════════════════════════════════════
                 EXCLUDE FILE PATTERNS  (collapsible + toggle all + custom)
                 ════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="EXCLUDE FILE PATTERNS"
                               Style="{StaticResource SectionTitle}"
                               Margin="0" VerticalOptions="Center" />
                        <Button Grid.Column="1"
                                Style="{StaticResource ToggleAllBtn}"
                                Text="Toggle all"
                                Command="{Binding ToggleAllFilePatternsCommand}"
                                IsVisible="{Binding IsFilePatternsExpanded}" />
                        <Label Grid.Column="2"
                               Text="{Binding IsFilePatternsExpanded, Converter={StaticResource ExpandArrowConv}}"
                               TextColor="{StaticResource TextMuted}" FontSize="12" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleFilePatternsCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleFilePatternsCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <Label Text="Enabled patterns exclude matching files (e.g. *Test* removes all test files)."
                           Style="{StaticResource HintLabel}"
                           IsVisible="{Binding IsFilePatternsExpanded}" />

                    <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start"
                                IsVisible="{Binding IsFilePatternsExpanded}">
                        <BindableLayout.ItemsSource>
                            <Binding Path="FilePatternFilters" />
                        </BindableLayout.ItemsSource>
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:FilePatternFilter">
                                <Border Style="{StaticResource ChipBorder}"
                                        BackgroundColor="{Binding IsEnabled, Converter={StaticResource ChipBgConv}}"
                                        Stroke="{Binding IsEnabled, Converter={StaticResource ChipBorderConv}}">
                                    <HorizontalStackLayout Spacing="4">
                                        <CheckBox IsChecked="{Binding IsEnabled}"
                                                  Color="{StaticResource AccentRed}"
                                                  VerticalOptions="Center" />
                                        <Label Text="{Binding Pattern}" Style="{StaticResource ChipLabel}" />
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8"
                          IsVisible="{Binding IsFilePatternsExpanded}" Margin="0,6,0,0">
                        <Border Grid.Column="0" Style="{StaticResource InputBorder}">
                            <Entry Style="{StaticResource InputEntry}"
                                   Text="{Binding CustomPatternInput}"
                                   Placeholder="e.g. *Scaffold* or *.backup.*"
                                   ReturnType="Done"
                                   ReturnCommand="{Binding AddCustomPatternCommand}"
                                   IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                        </Border>
                        <Button Grid.Column="1"
                                Style="{StaticResource ToggleAllBtn}"
                                Text="+ Add"
                                Command="{Binding AddCustomPatternCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ════════════════════════════════════════════════════
                 TOKEN SLIDER  (warning above, larger thumb)
                 ════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                        <Label Grid.Column="0" Text="MAX TOKENS / CHUNK"
                               Style="{StaticResource SectionTitle}"
                               Margin="0" VerticalOptions="Center" />
                        <Border Grid.Column="1" Style="{StaticResource TokenBadgeBorder}">
                            <Label Text="{Binding MaxTokensLabel}"
                                   Style="{StaticResource TokenBadgeLabel}" />
                        </Border>
                    </Grid>
                    <!-- Warning text above the slider -->
                    <Label Text="{Binding SliderWarningText}"
                           TextColor="{Binding SliderWarningColor}"
                           Style="{StaticResource SliderWarningLabel}" />
                    <Slider Minimum="1000" Maximum="30000"
                            Value="{Binding MaxTokensPerChunk}"
                            MinimumTrackColor="{StaticResource SliderTrackActive}"
                            MaximumTrackColor="{StaticResource SliderTrackInactive}"
                            ThumbColor="{StaticResource SliderThumb}"
                            HeightRequest="40"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                    <Grid ColumnDefinitions="*,*">
                        <Label Grid.Column="0" Text="1 000"
                               TextColor="{StaticResource TextDim}" FontSize="10" />
                        <Label Grid.Column="1" Text="30 000"
                               TextColor="{StaticResource TextDim}" FontSize="10"
                               HorizontalOptions="End" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ════════════════════════════════════════════════════
                 CHUNK BUTTON + ABORT / RESET
                 ════════════════════════════════════════════════════ -->
            <Button Text="Chunk"
                    Style="{StaticResource PrimaryBtn}"
                    Command="{Binding FetchCommand}"
                    Margin="0,0,0,8" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,0,0,12">
                <Button Grid.Column="0"
                        Text="Abort"
                        Style="{StaticResource SecondaryBtn}"
                        Command="{Binding CancelCommand}"
                        IsVisible="{Binding IsBusy}" />
                <Button Grid.Column="0" Grid.ColumnSpan="2"
                        Text="Reset"
                        Style="{StaticResource SecondaryBtn}"
                        Command="{Binding ResetCommand}"
                        IsVisible="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
            </Grid>

            <!-- ════════════════════════════════════════════════════
                 ACTIVITY / STATUS / ERROR
                 ════════════════════════════════════════════════════ -->
            <VerticalStackLayout IsVisible="{Binding IsBusy}"
                                 HorizontalOptions="Center"
                                 Spacing="10" Margin="0,0,0,10">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   Color="{StaticResource ActivityIndicatorColor}"
                                   HeightRequest="36" WidthRequest="36"
                                   HorizontalOptions="Center" />
                <Label Text="{Binding StatusText}"
                       TextColor="{StaticResource TextSecondary}"
                       FontSize="14" HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>

            <Border Style="{StaticResource StatusBorder}"
                    IsVisible="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                <Label Text="{Binding StatusText}" Style="{StaticResource StatusLabel}" />
            </Border>

            <Border Style="{StaticResource ErrorBorder}" IsVisible="{Binding HasError}">
                <Grid ColumnDefinitions="28,*" ColumnSpacing="8">
                    <Label Grid.Column="0" Text="⚠️" FontSize="18" VerticalOptions="Start" />
                    <Label Grid.Column="1" Text="{Binding ErrorText}" Style="{StaticResource ErrorLabel}" />
                </Grid>
            </Border>

            <!-- ════════════════════════════════════════════════════
                 SUMMARY STATS  (files · projects · chunks · tokens)
                 ════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource SummaryBorder}" IsVisible="{Binding HasChunks}">
                <Grid ColumnDefinitions="*,*,*,*">
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                        <Label Text="{Binding TotalFiles}"    Style="{StaticResource StatNumberLabel}" />
                        <Label Text="files"                   Style="{StaticResource StatCaptionLabel}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                        <Label Text="{Binding TotalProjects}" Style="{StaticResource StatNumberLabel}" />
                        <Label Text="projects"                Style="{StaticResource StatCaptionLabel}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                        <Label Text="{Binding ChunkCount}"    Style="{StaticResource StatNumberLabel}" />
                        <Label Text="chunks"                  Style="{StaticResource StatCaptionLabel}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="2">
                        <Label Text="{Binding TotalTokens}"   Style="{StaticResource StatNumberLabel}" />
                        <Label Text="tokens"                  Style="{StaticResource StatCaptionLabel}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════════════════════
                 AI PROMPTS  (collapsible)

                 · Tap title/preview area  → copy to clipboard
                   (card turns green; only one at a time)
                 · CheckBox (left)         → select prompt to prepend
                   on share (radio-button; only one at a time, handled
                   entirely in ViewModel via PropertyChanged subscription —
                   BUG FIX #1)
                 · ✎                       → edit inline
                 · ✕                       → delete (custom only)

                 BUG FIX #2: previously both the inner VerticalStackLayout
                 AND the parent Grid carried CopyPromptCommand gestures,
                 causing the clipboard to be written twice per tap and
                 IsCopied to toggle back to false.  The parent Grid gesture
                 is removed; only the title/preview VSL carries the tap.
                 ════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource Card}" IsVisible="{Binding HasChunks}">
                <VerticalStackLayout Spacing="0">

                    <!-- Header row -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="AI PROMPTS"
                               Style="{StaticResource SectionTitle}"
                               Margin="0" VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding IsPromptsExpanded, Converter={StaticResource ExpandArrowConv}}"
                               TextColor="{StaticResource TextMuted}" FontSize="12" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding TogglePromptsCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding TogglePromptsCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <VerticalStackLayout IsVisible="{Binding IsPromptsExpanded}" Spacing="0">

                        <Label Text="Tap a prompt to copy it. Check one to prepend it automatically when sharing chunks."
                               Style="{StaticResource HintLabel}" Margin="0,0,0,10" />

                        <CollectionView ItemsSource="{Binding Prompts}" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:PromptItem">

                                    <Border Style="{StaticResource PromptCardBorder}"
                                            BackgroundColor="{Binding CardBackgroundColor}"
                                            Stroke="{Binding CardBorderColor}">
                                        <VerticalStackLayout Spacing="0">

                                            <!-- ── VIEW MODE ── -->
                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                                  ColumnSpacing="4"
                                                  Padding="12,12,10,12"
                                                  IsVisible="{Binding IsEditing, Converter={StaticResource InverseBool}}">

                                                <!-- Share-select checkbox.
                                                     BUG FIX #1: TwoWay binding on IsChecked is all
                                                     that is needed here.  The ViewModel's
                                                     SubscribePrompt handler enforces single-select
                                                     by listening to PropertyChanged, so we do NOT
                                                     add a TapGestureRecognizer on this CheckBox —
                                                     that was what caused the immediate self-uncheck. -->
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsSelectedForShare}"
                                                          Color="{StaticResource AccentPrimary}"
                                                          VerticalOptions="Center"
                                                          Margin="0,0,4,0" />

                                                <!-- Title + preview tappable area → copy.
                                                     BUG FIX #2: gesture is ONLY on the inner VSL;
                                                     the parent Grid no longer carries a duplicate
                                                     CopyPromptCommand gesture. -->
                                                <VerticalStackLayout Grid.Column="1"
                                                                     Spacing="2"
                                                                     VerticalOptions="Center">
                                                    <Label Text="{Binding Title}"
                                                           Style="{StaticResource PromptTitleLabel}" />
                                                    <Label Text="{Binding PreviewText}"
                                                           Style="{StaticResource PromptPreviewLabel}" />
                                                    <VerticalStackLayout.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.CopyPromptCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    </VerticalStackLayout.GestureRecognizers>
                                                </VerticalStackLayout>

                                                <!-- Edit -->
                                                <Button Grid.Column="2"
                                                        Style="{StaticResource SmallIconBtn}"
                                                        Text="✎"
                                                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.StartEditPromptCommand}"
                                                        CommandParameter="{Binding .}"
                                                        ToolTipProperties.Text="Edit prompt" />

                                                <!-- Delete (custom prompts only) -->
                                                <Button Grid.Column="3"
                                                        Style="{StaticResource PromptDeleteBtn}"
                                                        Text="✕"
                                                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.DeletePromptCommand}"
                                                        CommandParameter="{Binding .}"
                                                        IsVisible="{Binding IsBuiltIn, Converter={StaticResource InverseBool}}"
                                                        ToolTipProperties.Text="Delete prompt" />

                                                <!-- NOTE: NO Grid.GestureRecognizers here.
                                                     Removed duplicate CopyPromptCommand (BUG FIX #2). -->
                                            </Grid>

                                            <!-- ── EDIT MODE ── -->
                                            <Border Style="{StaticResource PromptEditBorder}"
                                                    IsVisible="{Binding IsEditing}">
                                                <VerticalStackLayout Spacing="6">
                                                    <Label Text="Title" Style="{StaticResource FieldLabel}" />
                                                    <Border Style="{StaticResource InputBorder}">
                                                        <Entry Style="{StaticResource InputEntry}"
                                                               Text="{Binding EditTitle}"
                                                               Placeholder="Prompt title" />
                                                    </Border>

                                                    <Label Text="Prompt text"
                                                           Style="{StaticResource FieldLabel}"
                                                           Margin="0,6,0,0" />
                                                    <Border Style="{StaticResource InputBorder}">
                                                        <Editor Style="{StaticResource InlineEditor}"
                                                                Text="{Binding EditContent}"
                                                                Placeholder="Write your prompt… use [PASTE CHUNK] as a placeholder for the code." />
                                                    </Border>

                                                    <Grid ColumnDefinitions="*,Auto,Auto"
                                                          ColumnSpacing="8" Margin="0,6,0,0">
                                                        <Label Grid.Column="0"
                                                               Text="Use [PASTE CHUNK] to mark where the code goes."
                                                               Style="{StaticResource HintLabel}"
                                                               Margin="0" VerticalOptions="Center" />
                                                        <Button Grid.Column="1"
                                                                Style="{StaticResource PromptSaveBtn}"
                                                                Text="Save"
                                                                Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.SavePromptCommand}"
                                                                CommandParameter="{Binding .}" />
                                                        <Button Grid.Column="2"
                                                                Style="{StaticResource SmallIconBtn}"
                                                                Text="Cancel"
                                                                Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.CancelEditPromptCommand}"
                                                                CommandParameter="{Binding .}" />
                                                    </Grid>
                                                </VerticalStackLayout>
                                            </Border>

                                        </VerticalStackLayout>
                                    </Border>

                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Button Text="+ New prompt"
                                Style="{StaticResource SecondaryBtn}"
                                Command="{Binding AddNewPromptCommand}"
                                Margin="0,4,0,0" />

                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ════════════════════════════════════════════════════
                 CHUNK LIST
                 · Tap row body  → copy to clipboard (green)
                 · ↗             → share via share sheet
                 · ▼/▲           → preview file list
                 · CheckBox      → multi-select for batch share
                 ════════════════════════════════════════════════════ -->
            <VerticalStackLayout IsVisible="{Binding HasChunks}" Spacing="0">

                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                    <Label Grid.Column="0" Text="CHUNKS"
                           Style="{StaticResource SectionTitle}"
                           Margin="0" VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding HasSelection, Converter={StaticResource SelectionHintConv}}"
                           TextColor="{StaticResource TextMuted}" FontSize="11" VerticalOptions="Center" />
                </Grid>

                <!-- Multi-select toolbar -->
                <Border Style="{StaticResource SelectionToolbarBorder}"
                        IsVisible="{Binding HasSelection}">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="1">
                            <Label Text="{Binding ShareSelectedLabel}"
                                   Style="{StaticResource SelectionCountLabel}" />
                            <Label Text="{Binding SelectedTokensLabel}"
                                   Style="{StaticResource SelectionTokensLabel}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="✕"
                                Style="{StaticResource IconBtn}"
                                Command="{Binding ClearSelectionCommand}"
                                ToolTipProperties.Text="Deselect all" />
                        <Button Grid.Column="2"
                                Text="Share ↗"
                                Style="{StaticResource ShareBtn}"
                                Command="{Binding ShareSelectedCommand}" />
                    </Grid>
                </Border>

                <!-- Chunk cards -->
                <CollectionView ItemsSource="{Binding Chunks}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:CodeChunk">

                            <Border Style="{StaticResource ChunkBorder}"
                                    BackgroundColor="{Binding CardBackgroundColor}"
                                    Stroke="{Binding CardBorderColor}">
                                <VerticalStackLayout Spacing="0">

                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          RowDefinitions="Auto,Auto"
                                          Padding="14,12">

                                        <CheckBox Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                                                  IsChecked="{Binding IsSelected}"
                                                  Color="{StaticResource AccentPrimary}"
                                                  VerticalOptions="Center"
                                                  Margin="0,0,6,0" />

                                        <Label Grid.Row="0" Grid.Column="1"
                                               Text="{Binding DisplayLabel}"
                                               Style="{StaticResource ChunkTitleLabel}" />

                                        <Label Grid.Row="1" Grid.Column="1"
                                               Text="{Binding SubLabel}"
                                               Style="{StaticResource ChunkSubLabel}" />

                                        <HorizontalStackLayout Grid.Row="0" Grid.Column="2"
                                                               Grid.RowSpan="2"
                                                               Spacing="0" VerticalOptions="Center">
                                            <Button Text="↗"
                                                    Style="{StaticResource ChunkActionBtn}"
                                                    TextColor="{Binding CopyButtonTextColor}"
                                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ShareChunkCommand}"
                                                    CommandParameter="{Binding .}"
                                                    ToolTipProperties.Text="Share via share sheet" />
                                            <Button Text="{Binding PreviewToggleIcon}"
                                                    Style="{StaticResource ChunkActionBtn}"
                                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.TogglePreviewCommand}"
                                                    CommandParameter="{Binding .}"
                                                    ToolTipProperties.Text="Preview file list" />
                                        </HorizontalStackLayout>

                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.CopyChunkCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>
                                    </Grid>

                                    <Border Style="{StaticResource PreviewBorder}"
                                            IsVisible="{Binding IsPreviewExpanded}">
                                        <Label Text="{Binding PreviewSnippet}"
                                               Style="{StaticResource PreviewLabel}" />
                                    </Border>

                                </VerticalStackLayout>
                            </Border>

                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
