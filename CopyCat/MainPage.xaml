<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CopyCat.ViewModels"
             xmlns:models="clr-namespace:CopyCat.Models"
             x:Class="CopyCat.MainPage"
             x:DataType="vm:MainViewModel"
             x:Name="ThisPage"
             Title="CopyCat">

    <ScrollView VerticalScrollBarVisibility="Default">
        <VerticalStackLayout Padding="14,14,14,48" Spacing="0">

            <!-- ══════════════════════════════════════════════════
                 HEADER
                 ══════════════════════════════════════════════════ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <Grid ColumnDefinitions="56,*" ColumnSpacing="14">
                    <Image Grid.Column="0"
                           Source="copycat_logo.svg"
                           HeightRequest="52"
                           WidthRequest="52"
                           VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="CopyCat"
                               Style="{StaticResource HeaderTitle}" />
                        <Label Text="GitHub → chunks → AI"
                               Style="{StaticResource HeaderSubtitle}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════
                 REPOSITORY
                 ══════════════════════════════════════════════════ -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="0">
                    <Label Text="REPOSITORY" Style="{StaticResource SectionTitle}" />

                    <!-- GitHub URL -->
                    <Label Text="GitHub URL" Style="{StaticResource FieldLabel}" />
                    <Border Style="{StaticResource InputBorder}" Margin="0,0,0,10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry Grid.Column="0"
                                   Style="{StaticResource InputEntry}"
                                   Text="{Binding RepoUrl}"
                                   Placeholder="https://github.com/owner/repo"
                                   Keyboard="Url"
                                   ReturnType="Next"
                                   IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                            <Button Grid.Column="1"
                                    Style="{StaticResource IconBtn}"
                                    Text="📋"
                                    Command="{Binding PasteUrlCommand}"
                                    ToolTipProperties.Text="Klistra in från urklipp"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                        </Grid>
                    </Border>

                    <!-- ── Senaste URLs — dropdown picker ── -->
                    <Grid ColumnDefinitions="*,Auto"
                          IsVisible="{Binding HasRecentUrls}"
                          Margin="0,0,0,10">
                        <Border Grid.Column="0"
                                Style="{StaticResource RecentUrlsPickerBorder}"
                                Margin="0">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0"
                                       Text="🕐"
                                       FontSize="15"
                                       TextColor="{StaticResource TextMuted}"
                                       VerticalOptions="Center"
                                       Margin="12,0,0,0" />
                                <Picker Grid.Column="1"
                                        Style="{StaticResource InputPicker}"
                                        ItemsSource="{Binding RecentUrls}"
                                        SelectedItem="{Binding RepoUrl, Mode=OneWayToSource}"
                                        Title="Välj senast använd URL…"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ── Gren med dropdown ── -->
                    <Label Text="Gren" Style="{StaticResource FieldLabel}" />
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10" ColumnSpacing="8">

                        <!-- Picker visas när grenar är hämtade -->
                        <Border Grid.Column="0"
                                Style="{StaticResource InputBorder}"
                                IsVisible="{Binding HasBranchOptions}">
                            <Picker Style="{StaticResource InputPicker}"
                                    ItemsSource="{Binding BranchOptions}"
                                    SelectedItem="{Binding Branch}"
                                    Title="Välj gren…"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                        </Border>

                        <!-- Entry visas när inga grenar är hämtade -->
                        <Border Grid.Column="0"
                                Style="{StaticResource InputBorder}"
                                IsVisible="{Binding HasBranchOptions, Converter={StaticResource InverseBool}}">
                            <Entry Style="{StaticResource InputEntry}"
                                   Text="{Binding Branch}"
                                   Placeholder="main"
                                   ReturnType="Next"
                                   IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                        </Border>

                        <!-- Hämta grenar-knapp -->
                        <Border Grid.Column="1"
                                Style="{StaticResource InputBorder}"
                                WidthRequest="50"
                                HeightRequest="50">
                            <Grid>
                                <Button Style="{StaticResource IconBtn}"
                                        Text="⇅"
                                        Command="{Binding FetchBranchesCommand}"
                                        ToolTipProperties.Text="Hämta tillgängliga grenar"
                                        IsEnabled="{Binding IsFetchingBranches, Converter={StaticResource InverseBool}}"
                                        IsVisible="{Binding IsFetchingBranches, Converter={StaticResource InverseBool}}" />
                                <ActivityIndicator IsRunning="{Binding IsFetchingBranches}"
                                                   IsVisible="{Binding IsFetchingBranches}"
                                                   Color="{StaticResource AccentPrimary}"
                                                   HeightRequest="22" WidthRequest="22"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ── Token ── -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                        <Label Grid.Column="0"
                               Text="GitHub Token (privata repos)"
                               Style="{StaticResource FieldLabel}"
                               Margin="0"
                               VerticalOptions="Center" />
                        <Border Grid.Column="1"
                                Style="{StaticResource SavedTokenBorder}"
                                IsVisible="{Binding TokenIsSaved}">
                            <Label Text="✓ Sparad"
                                   TextColor="{StaticResource AccentGreen}"
                                   FontSize="11"
                                   FontAttributes="Bold" />
                        </Border>
                    </Grid>
                    <Border Style="{StaticResource InputBorder}">
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry Grid.Column="0"
                                   Style="{StaticResource InputEntry}"
                                   Text="{Binding AccessToken}"
                                   Placeholder="ghp_… (lämna tomt för publika repos)"
                                   IsPassword="True"
                                   ReturnType="Done"
                                   IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                            <Button Grid.Column="1"
                                    Style="{StaticResource IconBtn}"
                                    Text="🗑"
                                    Command="{Binding ClearTokenCommand}"
                                    IsVisible="{Binding TokenIsSaved}"
                                    ToolTipProperties.Text="Rensa sparad token" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- ══════════════════════════════════════════════════
                 FILE TYPES (expandable)
                 ══════════════════════════════════════════════════ -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="FILTYPER"
                               Style="{StaticResource SectionTitle}" Margin="0" VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding IsFileTypesExpanded, Converter={StaticResource ExpandArrowConv}}"
                               TextColor="{StaticResource TextMuted}" FontSize="12" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleFileTypesCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleFileTypesCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>
                    <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start"
                                IsVisible="{Binding IsFileTypesExpanded}">
                        <BindableLayout.ItemsSource>
                            <Binding Path="FileTypeFilters" />
                        </BindableLayout.ItemsSource>
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:FileTypeFilter">
                                <Border Style="{StaticResource ChipBorder}"
                                        BackgroundColor="{Binding IsEnabled, Converter={StaticResource ChipBgConv}}"
                                        Stroke="{Binding IsEnabled, Converter={StaticResource ChipBorderConv}}">
                                    <HorizontalStackLayout Spacing="4">
                                        <CheckBox IsChecked="{Binding IsEnabled}"
                                                  Color="{StaticResource AccentPrimary}"
                                                  VerticalOptions="Center" />
                                        <Label Text="{Binding Label}" Style="{StaticResource ChipLabel}" />
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ══════════════════════════════════════════════════
                 EXCLUDED FOLDERS (expandable)
                 ══════════════════════════════════════════════════ -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="EXKLUDERA MAPPAR"
                               Style="{StaticResource SectionTitle}" Margin="0" VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding IsFoldersExpanded, Converter={StaticResource ExpandArrowConv}}"
                               TextColor="{StaticResource TextMuted}" FontSize="12" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleFoldersCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleFoldersCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>
                    <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start"
                                IsVisible="{Binding IsFoldersExpanded}">
                        <BindableLayout.ItemsSource>
                            <Binding Path="FolderFilters" />
                        </BindableLayout.ItemsSource>
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:FolderFilter">
                                <Border Style="{StaticResource ChipBorder}"
                                        BackgroundColor="{Binding IsExcluded, Converter={StaticResource ChipBgConv}}"
                                        Stroke="{Binding IsExcluded, Converter={StaticResource ChipBorderConv}}">
                                    <HorizontalStackLayout Spacing="4">
                                        <CheckBox IsChecked="{Binding IsExcluded}"
                                                  Color="{StaticResource AccentGreen}"
                                                  VerticalOptions="Center" />
                                        <Label Text="{Binding Name}" Style="{StaticResource ChipLabel}" />
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ══════════════════════════════════════════════════
                 EXCLUDE FILE PATTERNS (expandable)
                 Aktiverade mönster UTESLUTER matchande filer.
                 ══════════════════════════════════════════════════ -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="EXKLUDERA FILMÖNSTER"
                               Style="{StaticResource SectionTitle}" Margin="0" VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding IsFilePatternsExpanded, Converter={StaticResource ExpandArrowConv}}"
                               TextColor="{StaticResource TextMuted}" FontSize="12" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleFilePatternsCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleFilePatternsCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <Label Text="Aktiverade mönster exkluderar matchande filer (t.ex. *Test* tar bort alla testfiler)."
                           TextColor="{StaticResource TextMuted}"
                           FontSize="11"
                           LineBreakMode="WordWrap"
                           Margin="0,0,0,8"
                           IsVisible="{Binding IsFilePatternsExpanded}" />

                    <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start"
                                IsVisible="{Binding IsFilePatternsExpanded}">
                        <BindableLayout.ItemsSource>
                            <Binding Path="FilePatternFilters" />
                        </BindableLayout.ItemsSource>
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:FilePatternFilter">
                                <Border Style="{StaticResource ChipBorder}"
                                        BackgroundColor="{Binding IsEnabled, Converter={StaticResource ChipBgConv}}"
                                        Stroke="{Binding IsEnabled, Converter={StaticResource ChipBorderConv}}">
                                    <HorizontalStackLayout Spacing="4">
                                        <CheckBox IsChecked="{Binding IsEnabled}"
                                                  Color="{StaticResource TextError}"
                                                  VerticalOptions="Center" />
                                        <Label Text="{Binding Pattern}" Style="{StaticResource ChipLabel}" />
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ══════════════════════════════════════════════════
                 TOKEN SLIDER
                 ══════════════════════════════════════════════════ -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                        <Label Grid.Column="0" Text="MAX TOKENS / CHUNK"
                               Style="{StaticResource SectionTitle}" Margin="0" VerticalOptions="Center" />
                        <Border Grid.Column="1" Style="{StaticResource TokenBadgeBorder}">
                            <Label Text="{Binding MaxTokensLabel}" Style="{StaticResource TokenBadgeLabel}" />
                        </Border>
                    </Grid>
                    <Slider Minimum="1000" Maximum="30000"
                            Value="{Binding MaxTokensPerChunk}"
                            MinimumTrackColor="{StaticResource SliderTrackActive}"
                            MaximumTrackColor="{StaticResource SliderTrackInactive}"
                            ThumbColor="{StaticResource SliderThumb}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                    <Grid ColumnDefinitions="*,*" Margin="0,0,0,6">
                        <Label Grid.Column="0" Text="1 000"
                               TextColor="{StaticResource TextDim}" FontSize="10" />
                        <Label Grid.Column="1" Text="30 000"
                               TextColor="{StaticResource TextDim}" FontSize="10" HorizontalOptions="End" />
                    </Grid>

                    <!-- Kontextuell varning/info baserat på valt tokenvärde -->
                    <Label Text="{Binding SliderWarningText}"
                           TextColor="{Binding SliderWarningColor}"
                           Style="{StaticResource SliderWarningLabel}" />
                </VerticalStackLayout>
            </Border>

            <!-- ══════════════════════════════════════════════════
                 FETCH BUTTON
                 ══════════════════════════════════════════════════ -->
            <Button Text="Chunk"
                    Style="{StaticResource PrimaryBtn}"
                    Command="{Binding FetchCommand}"
                    Margin="0,0,0,8" />

            <!-- Cancel / Reset -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,0,0,12">
                <Button Grid.Column="0"
                        Text="Abort"
                        Style="{StaticResource SecondaryBtn}"
                        Command="{Binding CancelCommand}"
                        IsVisible="{Binding IsBusy}" />
                <Button Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Text="Reset"
                        Style="{StaticResource SecondaryBtn}"
                        Command="{Binding ResetCommand}"
                        IsVisible="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
            </Grid>

            <!-- ══════════════════════════════════════════════════
                 ACTIVITY INDICATOR
                 ══════════════════════════════════════════════════ -->
            <VerticalStackLayout IsVisible="{Binding IsBusy}"
                                 HorizontalOptions="Center" Spacing="10" Margin="0,0,0,10">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   Color="{StaticResource ActivityIndicatorColor}"
                                   HeightRequest="36" WidthRequest="36"
                                   HorizontalOptions="Center" />
                <Label Text="{Binding StatusText}"
                       TextColor="{StaticResource TextSecondary}"
                       FontSize="14" HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" LineBreakMode="WordWrap" />
            </VerticalStackLayout>

            <!-- ══════════════════════════════════════════════════
                 STATUS BAR
                 ══════════════════════════════════════════════════ -->
            <Border Style="{StaticResource StatusBorder}"
                    IsVisible="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                <Label Text="{Binding StatusText}" Style="{StaticResource StatusLabel}" />
            </Border>

            <!-- ══════════════════════════════════════════════════
                 ERROR PANEL
                 ══════════════════════════════════════════════════ -->
            <Border Style="{StaticResource ErrorBorder}" IsVisible="{Binding HasError}">
                <Grid ColumnDefinitions="28,*" ColumnSpacing="8">
                    <Label Grid.Column="0" Text="⚠️" FontSize="18" VerticalOptions="Start" />
                    <Label Grid.Column="1" Text="{Binding ErrorText}" Style="{StaticResource ErrorLabel}" />
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════
                 SUMMARY STATS
                 ══════════════════════════════════════════════════ -->
            <Border Style="{StaticResource SummaryBorder}" IsVisible="{Binding HasChunks}">
                <Grid ColumnDefinitions="*,*,*,*">
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                        <Label Text="{Binding TotalFiles}" Style="{StaticResource StatNumberLabel}" />
                        <Label Text="filer" Style="{StaticResource StatCaptionLabel}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                        <Label Text="{Binding TotalProjects}" Style="{StaticResource StatNumberLabel}" />
                        <Label Text="projekt" Style="{StaticResource StatCaptionLabel}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                        <Label Text="{Binding ChunkCount}" Style="{StaticResource StatNumberLabel}" />
                        <Label Text="chunks" Style="{StaticResource StatCaptionLabel}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="2">
                        <Label Text="{Binding CopiedCount}" Style="{StaticResource StatNumberLabel}" />
                        <Label Text="kopierade" Style="{StaticResource StatCaptionLabel}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════
                 CHUNK LIST
                 ══════════════════════════════════════════════════ -->
            <VerticalStackLayout IsVisible="{Binding HasChunks}" Spacing="0">

                <!-- Rubrik + instruktion -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                    <Label Grid.Column="0"
                           Text="CHUNKS"
                           Style="{StaticResource SectionTitle}"
                           Margin="0" VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding HasSelection, Converter={StaticResource SelectionHintConv}}"
                           TextColor="{StaticResource TextMuted}"
                           FontSize="11" VerticalOptions="Center" />
                </Grid>

                <!-- Multi-select toolbar -->
                <Border Style="{StaticResource SelectionToolbarBorder}"
                        IsVisible="{Binding HasSelection}">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="1">
                            <Label Text="{Binding ShareSelectedLabel}"
                                   Style="{StaticResource SelectionCountLabel}" />
                            <Label Text="{Binding SelectedTokensLabel}"
                                   Style="{StaticResource SelectionTokensLabel}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="✕"
                                Style="{StaticResource IconBtn}"
                                Command="{Binding ClearSelectionCommand}"
                                ToolTipProperties.Text="Avmarkera alla" />
                        <Button Grid.Column="2"
                                Text="Dela ↗"
                                Style="{StaticResource ShareBtn}"
                                Command="{Binding ShareSelectedCommand}" />
                    </Grid>
                </Border>

                <!-- ═══════════════════════════════════════════
                     CHUNK-KORT
                     - Tryck på kortet    → kopiera till urklipp (kort blir GRÖNT, bara ett åt gången)
                     - Dela-knapp (↗)     → share sheet för denna chunk
                     - Förhandsgranskning (▼/▲) → expandera/kollapsa fillistning
                     - Checkbox           → multi-select
                     ═══════════════════════════════════════════ -->
                <CollectionView ItemsSource="{Binding Chunks}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:CodeChunk">

                            <!--
                                BackgroundColor och Stroke binds direkt till computed properties
                                på CodeChunk som hanterar prioritering: kopierad > markerad > standard.
                            -->
                            <Border Style="{StaticResource ChunkBorder}"
                                    BackgroundColor="{Binding CardBackgroundColor}"
                                    Stroke="{Binding CardBorderColor}">

                                <VerticalStackLayout Spacing="0">

                                    <!-- Huvud-rad -->
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          RowDefinitions="Auto,Auto"
                                          Padding="14,12">

                                        <!-- Kolumn 0: Checkbox för multi-select (sträcker sig två rader) -->
                                        <CheckBox Grid.Row="0" Grid.Column="0"
                                                  Grid.RowSpan="2"
                                                  IsChecked="{Binding IsSelected}"
                                                  Color="{StaticResource AccentPrimary}"
                                                  VerticalOptions="Center"
                                                  Margin="0,0,6,0" />

                                        <!-- Kolumn 1: Titel -->
                                        <Label Grid.Row="0" Grid.Column="1"
                                               Text="{Binding DisplayLabel}"
                                               Style="{StaticResource ChunkTitleLabel}" />

                                        <!-- Kolumn 1: Sublabel (tokens) -->
                                        <Label Grid.Row="1" Grid.Column="1"
                                               Text="{Binding SubLabel}"
                                               Style="{StaticResource ChunkSubLabel}" />

                                        <!--
                                            Kolumn 2: Åtgärdsknappar HORISONTELLT
                                            (dela ↗ och förhandsvisning ▼/▲ sida vid sida)
                                        -->
                                        <HorizontalStackLayout Grid.Row="0" Grid.Column="2"
                                                               Grid.RowSpan="2"
                                                               Spacing="0"
                                                               VerticalOptions="Center">

                                            <!-- Dela (↗) — share sheet för just denna chunk -->
                                            <Button Text="↗"
                                                    Style="{StaticResource ChunkActionBtn}"
                                                    TextColor="{Binding CopyButtonTextColor}"
                                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ShareChunkCommand}"
                                                    CommandParameter="{Binding .}"
                                                    ToolTipProperties.Text="Dela via share sheet" />

                                            <!-- Förhandsvisning (▼/▲) -->
                                            <Button Text="{Binding PreviewToggleIcon}"
                                                    Style="{StaticResource ChunkActionBtn}"
                                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.TogglePreviewCommand}"
                                                    CommandParameter="{Binding .}"
                                                    ToolTipProperties.Text="Förhandsgranska innehåll" />
                                        </HorizontalStackLayout>

                                        <!-- Tryck på hela raden = kopiera till urklipp -->
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.CopyChunkCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>
                                    </Grid>

                                    <!-- Förhandsvisning — fillistning, expanderas vid tryck på ▼ -->
                                    <Border Style="{StaticResource PreviewBorder}"
                                            IsVisible="{Binding IsPreviewExpanded}">
                                        <Label Text="{Binding PreviewSnippet}"
                                               Style="{StaticResource PreviewLabel}" />
                                    </Border>

                                </VerticalStackLayout>
                            </Border>

                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
